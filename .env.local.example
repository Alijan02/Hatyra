# Скопируй этот файл в .env.local и заполни значения.
#
# Локально достаточно ADMIN_PASSWORD и AUTH_SECRET — заявки будут
# сохраняться в /tmp/hatyra-data.json. На продакшене (Vercel) дополнительно
# нужен Upstash Redis: KV_REST_API_URL + KV_REST_API_TOKEN (выдаст Vercel
# при подключении интеграции).

# Пароль для входа в /admin. На локалке можно оставить admin.
ADMIN_PASSWORD=admin

# Секрет для подписи cookie сессии. Любая длинная случайная строка.
# Сгенерировать: `openssl rand -base64 32`
AUTH_SECRET=measure-thrice-cut-once-change-me-in-production-please

# (опционально) Для пересылки заявок в Telegram
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# (опционально, но рекомендуется) Email-уведомления клиенту
# при изменении статуса или сообщения через https://resend.com.
# Без этих переменных модуль молча логирует письма в консоль — не падает.
# RESEND_API_KEY=re_xxxxxxxxxxxx
# EMAIL_FROM="Hatyra <onboarding@resend.dev>"
# Заметка: onboarding@resend.dev — служебный домен Resend для тестов.
# Он отправит письма ТОЛЬКО на email из твоего аккаунта Resend (защита от спама).
# Когда подключишь свой домен в Resend — поменяешь на noreply@hatyra.tm

# (опционально) Базовый URL сайта для ссылок в письмах. Если не задан —
# берётся из заголовка запроса. На продакшене лучше задать явно.
# PUBLIC_BASE_URL=https://hatyra.com

# (продакшен) Upstash Redis — Vercel KV. Подставит автоматически
# при подключении интеграции через Vercel Marketplace.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=